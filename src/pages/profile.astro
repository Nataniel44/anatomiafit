---
import Layout from '../layouts/Layout.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout title="Perfil - Anatomía Fit">
  <main class="p-6 pb-24">
    <!-- Avatar Section -->
    <div class="flex flex-col items-center mb-8">
      <button id="avatarBtn" class="relative group">
        <div id="avatarContainer" class="w-24 h-24 rounded-full bg-gradient-to-br from-primary to-emerald-600 flex items-center justify-center shadow-lg shadow-primary/30">
          <span id="avatarIcon" class="material-symbols-outlined text-4xl text-white" style="font-variation-settings: 'FILL' 1">person</span>
        </div>
        <div class="absolute bottom-0 right-0 w-8 h-8 bg-surface-container-high rounded-full flex items-center justify-center border-2 border-surface">
          <span class="material-symbols-outlined text-sm text-slate-400">edit</span>
        </div>
      </button>
      <h1 class="font-headline font-black text-2xl text-on-surface mt-4" id="userName">Cargando...</h1>
      <p class="text-slate-400 text-sm" id="userEmail">...</p>
    </div>

    <!-- Avatar Selector Modal -->
    <div id="avatarModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
      <div class="bg-surface-container-low rounded-3xl p-6 w-full max-w-sm border border-white/10">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-headline font-bold text-xl text-on-surface">Seleccionar Icono</h3>
          <button id="closeAvatarModal" class="p-2 hover:bg-surface-container-high rounded-full transition-colors">
            <span class="material-symbols-outlined text-slate-400">close</span>
          </button>
        </div>
        <div class="grid grid-cols-5 gap-3 max-h-[300px] overflow-y-auto p-2">
          {['person', 'fitness_center', 'sports_gymnastics', 'directions_run', 'pool', 'sports_martial_arts', 'sports_handball', 'sports_soccer', 'sports_basketball', 'sports_tennis', 'self_improvement', 'accessibility_new', 'front_hand', 'accessibility', 'psychology', 'military_tech', 'workspace_premium', 'emoji_events', 'stars', 'auto_awesome', 'bolt', 'lightning', 'local_fire_department', 'whatshot', 'rocket_launch', 'celebration', 'cake', 'weekend', 'pets', 'cruelty_free'].map(icon => (
            <button class={`avatar-option w-12 h-12 rounded-xl flex items-center justify-center bg-surface-container-high hover:bg-surface-container-highest transition-all border border-white/5 ${icon === 'person' ? 'border-primary' : ''}`} data-icon={icon}>
              <span class="material-symbols-outlined text-xl text-slate-300" style={`font-variation-settings: 'FILL' 1`}>{icon}</span>
            </button>
          ))}
        </div>
        <button id="saveAvatar" class="w-full mt-4 py-3 bg-primary text-background font-bold rounded-2xl hover:bg-primary/90 transition-all">
          Guardar
        </button>
      </div>
    </div>

    <div class="space-y-4">
      <div class="bg-surface-container-low p-4 rounded-2xl border border-white/5">
        <h3 class="font-headline font-bold text-sm text-slate-400 uppercase tracking-widest mb-3">Cuenta</h3>
        <div class="space-y-3">
          <button id="editProfileBtn" class="w-full flex items-center gap-3 p-3 rounded-xl hover:bg-surface-container-high transition-colors text-left">
            <span class="material-symbols-outlined text-primary">edit</span>
            <span class="text-on-surface">Editar Nombre</span>
          </button>
        </div>
      </div>

      <div class="bg-surface-container-low p-4 rounded-2xl border border-white/5">
        <h3 class="font-headline font-bold text-sm text-slate-400 uppercase tracking-widest mb-3">App</h3>
        <div class="space-y-3">
          <button class="w-full flex items-center gap-3 p-3 rounded-xl hover:bg-surface-container-high transition-colors text-left">
            <span class="material-symbols-outlined text-secondary">language</span>
            <span class="text-on-surface">Idioma</span>
          </button>
        </div>
      </div>

      <button id="logoutBtn" class="w-full flex items-center gap-3 p-4 rounded-2xl bg-red-500/10 hover:bg-red-500/20 transition-colors text-left border border-red-500/20">
        <span class="material-symbols-outlined text-red-400">logout</span>
        <span class="text-red-400 font-bold">Cerrar Sesión</span>
      </button>
    </div>
  </main>
  <BottomNav activeTab="profile" />
</Layout>

<!-- Edit Name Modal -->
<div id="editNameModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
  <div class="bg-surface-container-low rounded-3xl p-6 w-full max-w-sm border border-white/10">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-headline font-bold text-xl text-on-surface">Editar Nombre</h3>
      <button id="closeNameModal" class="p-2 hover:bg-surface-container-high rounded-full transition-colors">
        <span class="material-symbols-outlined text-slate-400">close</span>
      </button>
    </div>
    <input 
      type="text" 
      id="nameInput" 
      class="w-full px-4 py-3 rounded-2xl bg-surface-container-high border border-white/10 text-on-surface placeholder-slate-500 focus:outline-none focus:border-primary transition-colors"
      placeholder="Tu nombre"
    />
    <button id="saveName" class="w-full mt-4 py-3 bg-primary text-background font-bold rounded-2xl hover:bg-primary/90 transition-all">
      Guardar
    </button>
  </div>
</div>

<script>
  const stored = localStorage.getItem('pb_auth');
  if (!stored) {
    window.location.href = '/login';
  }

  let authData = null;
  let selectedIcon = 'person';

  try {
    authData = JSON.parse(stored);
    if (authData.model) {
      const nameEl = document.getElementById('userName');
      const emailEl = document.getElementById('userEmail');
      const avatarIcon = document.getElementById('avatarIcon');
      
      if (nameEl && authData.model.name) {
        nameEl.textContent = authData.model.name;
      } else if (nameEl && authData.model.email) {
        nameEl.textContent = authData.model.email.split('@')[0];
      }
      if (emailEl && authData.model.email) {
        emailEl.textContent = authData.model.email;
      }
      if (avatarIcon && authData.model.avatar) {
        avatarIcon.textContent = authData.model.avatar;
        selectedIcon = authData.model.avatar;
      }
    }
  } catch (e) {
    window.location.href = '/login';
  }

  // Avatar Modal
  const avatarBtn = document.getElementById('avatarBtn');
  const avatarModal = document.getElementById('avatarModal');
  const closeAvatarModal = document.getElementById('closeAvatarModal');
  const saveAvatar = document.getElementById('saveAvatar');
  const avatarIcon = document.getElementById('avatarIcon');
  const avatarContainer = document.getElementById('avatarContainer');

  avatarBtn?.addEventListener('click', () => {
    avatarModal?.classList.remove('hidden');
    avatarModal?.classList.add('flex');
  });

  closeAvatarModal?.addEventListener('click', () => {
    avatarModal?.classList.add('hidden');
    avatarModal?.classList.remove('flex');
  });

  document.querySelectorAll('.avatar-option').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.avatar-option').forEach(b => b.classList.remove('border-primary'));
      btn.classList.add('border-primary');
      selectedIcon = btn.getAttribute('data-icon') || 'person';
    });
  });

  saveAvatar?.addEventListener('click', async () => {
    if (authData?.model?.id) {
      try {
        await fetch('https://imggreff.elysrestobar.com/api/collections/users/records/' + authData.model.id, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer ' + authData.token
          },
          body: JSON.stringify({ avatar: selectedIcon })
        });
        authData.model.avatar = selectedIcon;
        localStorage.setItem('pb_auth', JSON.stringify(authData));
        avatarIcon.textContent = selectedIcon;
      } catch (e) {
        console.error('Error saving avatar', e);
      }
    }
    avatarModal?.classList.add('hidden');
    avatarModal?.classList.remove('flex');
  });

  // Edit Name Modal
  const editProfileBtn = document.getElementById('editProfileBtn');
  const editNameModal = document.getElementById('editNameModal');
  const closeNameModal = document.getElementById('closeNameModal');
  const nameInput = document.getElementById('nameInput');
  const saveName = document.getElementById('saveName');
  const userName = document.getElementById('userName');

  editProfileBtn?.addEventListener('click', () => {
    nameInput.value = userName?.textContent || '';
    editNameModal?.classList.remove('hidden');
    editNameModal?.classList.add('flex');
  });

  closeNameModal?.addEventListener('click', () => {
    editNameModal?.classList.add('hidden');
    editNameModal?.classList.remove('flex');
  });

  saveName?.addEventListener('click', async () => {
    const newName = nameInput.value.trim();
    if (newName && authData?.model?.id) {
      try {
        await fetch('https://imggreff.elysrestobar.com/api/collections/users/records/' + authData.model.id, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer ' + authData.token
          },
          body: JSON.stringify({ name: newName })
        });
        authData.model.name = newName;
        localStorage.setItem('pb_auth', JSON.stringify(authData));
        userName.textContent = newName;
      } catch (e) {
        console.error('Error saving name', e);
      }
    }
    editNameModal?.classList.add('hidden');
    editNameModal?.classList.remove('flex');
  });

  // Close modals on outside click
  avatarModal?.addEventListener('click', (e) => {
    if (e.target === avatarModal) {
      avatarModal.classList.add('hidden');
      avatarModal.classList.remove('flex');
    }
  });

  editNameModal?.addEventListener('click', (e) => {
    if (e.target === editNameModal) {
      editNameModal.classList.add('hidden');
      editNameModal.classList.remove('flex');
    }
  });

  // Logout
  const logoutBtn = document.getElementById('logoutBtn');
  logoutBtn?.addEventListener('click', () => {
    localStorage.removeItem('pb_auth');
    window.location.href = '/';
  });
</script>