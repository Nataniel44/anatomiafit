---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Login - Anatomía Fit">
  <div class="min-h-screen bg-surface flex items-center justify-center p-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-primary/20 rounded-full mb-4">
          <span class="material-symbols-outlined text-4xl text-primary" style="font-variation-settings: 'FILL' 1">fitness_center</span>
        </div>
        <h1 class="font-headline font-black text-3xl text-on-surface">Anatomía Fit</h1>
        <p class="text-slate-400 mt-2">Inicia sesión para continuar</p>
      </div>

      <form id="loginForm" class="space-y-4">
        <div>
          <label class="block text-sm text-slate-400 mb-2 font-bold">Email</label>
          <input 
            type="email" 
            id="email" 
            required
            autocomplete="email"
            class="w-full px-4 py-3 rounded-2xl bg-surface-container-high border border-white/10 text-on-surface placeholder-slate-500 focus:outline-none focus:border-primary transition-colors"
            placeholder="tu@email.com"
          />
        </div>

        <div>
          <label class="block text-sm text-slate-400 mb-2 font-bold">Contraseña</label>
          <input 
            type="password" 
            id="password" 
            required
            autocomplete="current-password"
            class="w-full px-4 py-3 rounded-2xl bg-surface-container-high border border-white/10 text-on-surface placeholder-slate-500 focus:outline-none focus:border-primary transition-colors"
            placeholder="••••••••"
          />
        </div>

        <div id="error" class="text-red-400 text-sm hidden"></div>

        <button 
          type="submit"
          class="w-full py-4 bg-primary text-background font-bold rounded-2xl hover:bg-primary/90 transition-all duration-300 shadow-lg shadow-primary/20"
        >
          Iniciar Sesión
        </button>
      </form>

      <div class="mt-6 p-4 bg-surface-container-low rounded-2xl">
        <p class="text-slate-400 text-xs text-center mb-2">¿Ya tienes sesión activa?</p>
        <button id="logoutBtn" class="w-full py-2 text-slate-400 hover:text-red-400 text-sm transition-colors">
          Cerrar sesión
        </button>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('loginForm');
    const errorDiv = document.getElementById('error');
    const logoutBtn = document.getElementById('logoutBtn');
    
    const stored = localStorage.getItem('pb_auth');
    if (stored) {
      try {
        const authData = JSON.parse(stored);
        if (authData.token) {
          window.location.href = '/';
        }
      } catch (e) {
        console.error('Auth restore failed', e);
      }
    }
    
    logoutBtn?.addEventListener('click', () => {
      localStorage.removeItem('pb_auth');
      window.location.reload();
    });
    
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const emailInput = document.getElementById('email');
      const passwordInput = document.getElementById('password');
      const email = emailInput.value.trim();
      const password = passwordInput.value;
      
      try {
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), 10000);
        
        // Try user collection auth
        const result = await fetch('https://imggreff.elysrestobar.com/api/collections/users/auth-with-password', {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ 
            identity: email,
            password: password
          }),
          signal: controller.signal
        });
        
        clearTimeout(timeoutId);
        
        console.log('Response status:', result.status);
        
        if (!result.ok) {
          // Maybe user doesn't exist, try to create one
          const createResult = await fetch('https://imggreff.elysrestobar.com/api/collections/users/records', {
            method: 'POST',
            headers: { 
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify({ 
              email: email,
              password: password,
              passwordConfirm: password,
              name: email.split('@')[0]
            }),
            signal: controller.signal
          });
          
          console.log('Create response status:', createResult.status);
          
          if (createResult.ok) {
            // User created, now try to login
            const loginResult = await fetch('https://imggreff.elysrestobar.com/api/collections/users/auth-with-password', {
              method: 'POST',
              headers: { 
                'Content-Type': 'application/json',
                'Accept': 'application/json'
              },
              body: JSON.stringify({ 
                identity: email,
                password: password
              })
            });
            
            if (loginResult.ok) {
              const auth = await loginResult.json();
              localStorage.setItem('pb_auth', JSON.stringify({
                token: auth.token,
                model: auth.record
              }));
              window.location.href = '/';
              return;
            }
          }
          
          const errorText = await result.text();
          console.log('Error response:', errorText);
          if (errorDiv) {
            errorDiv.textContent = 'Email o contraseña incorrectos';
            errorDiv.classList.remove('hidden');
          }
          return;
        }
        
        const auth = await result.json();
        console.log('Auth success:', auth);
        
        localStorage.setItem('pb_auth', JSON.stringify({
          token: auth.token,
          model: auth.record
        }));
        
        window.location.href = '/';
      } catch (err) {
        console.error('Login error:', err);
        if (errorDiv) {
          errorDiv.textContent = err.name === 'AbortError' ? 'Tiempo de espera agotado' : 'Email o contraseña incorrectos';
          errorDiv.classList.remove('hidden');
        }
      }
    });
  </script>
</Layout>